```java
// === WasteEntryServiceTest.java ===
@ExtendWith(MockitoExtension.class)
class WasteEntryServiceTest {

    @Mock WasteEntryRepository repo;
    @InjectMocks WasteEntryService service;

    @Test void save_persistsEntry() {
        WasteEntry e = new WasteEntry();
        when(repo.save(e)).thenReturn(e);
        assertNotNull(service.save(e));
    }

    @Test void findByIndustry_returnsEmpty_whenNone() {
        when(repo.findByIndustryId(99L)).thenReturn(List.of());
        assertTrue(service.findByIndustryId(99L).isEmpty());
    }
}

// === WasteEntryReductionRateTest.java ===
class WasteEntryReductionRateTest {

    @Test void reductionRate_zero_whenGeneratedIsZero() {
        WasteEntry e = new WasteEntry();
        e.setPlasticGeneratedKg(0.0);
        assertEquals(0.0, e.getReductionRate());
    }

    @Test void reductionRate_correctCalculation() {
        WasteEntry e = new WasteEntry();
        e.setPlasticGeneratedKg(100.0);
        e.setPlasticRecycledKg(40.0);
        e.setPlasticEliminatedKg(20.0);
        assertEquals(60.0, e.getReductionRate(), 0.01);
    }
}

// === UserServiceTest.java ===
@ExtendWith(MockitoExtension.class)
class UserServiceTest {

    @Mock UserRepository userRepo;
    @Mock RoleRepository roleRepo;
    @Mock PasswordEncoder encoder;
    @InjectMocks UserService service;

    @Test void register_encodesPassword_andAssignsRole() {
        User u = new User(); u.setPassword("raw");
        Role r = new Role("ROLE_INDUSTRY");
        when(roleRepo.findByName("ROLE_INDUSTRY")).thenReturn(Optional.of(r));
        when(encoder.encode("raw")).thenReturn("encoded");
        when(userRepo.save(any())).thenAnswer(i -> i.getArgument(0));
        User saved = service.registerUser(u, "ROLE_INDUSTRY");
        assertEquals("encoded", saved.getPassword());
        assertTrue(saved.getRoles().contains(r));
    }

    @Test void toggle_disablesEnabledUser() {
        User u = new User(); u.setId(1L); u.setEnabled(true);
        when(userRepo.findById(1L)).thenReturn(Optional.of(u));
        service.toggleUserStatus(1L);
        assertFalse(u.isEnabled());
    }
}

// === PredictionServiceTest.java ===
@ExtendWith(MockitoExtension.class)
class PredictionServiceTest {

    @Mock WasteEntryRepository wasteRepo;
    @Mock IndustryRepository industryRepo;
    @InjectMocks PredictionService service;

    @Test void predict_returnsInsufficientData_whenLessThan3Entries() {
        Industry ind = new Industry(); ind.setName("Test");
        when(industryRepo.findById(1L)).thenReturn(Optional.of(ind));
        // Only 2 entries
        when(wasteRepo.findByIndustryId(1L)).thenReturn(makeTwoEntries());
        PredictionResult r = service.predictNextMonthWaste(1L);
        assertFalse(r.isSufficientData());
        assertNotNull(r.getInsufficientDataMessage());
    }

    @Test void predict_returnsForecast_whenSufficientData() {
        Industry ind = new Industry(); ind.setName("Test");
        when(industryRepo.findById(1L)).thenReturn(Optional.of(ind));
        when(wasteRepo.findByIndustryId(1L)).thenReturn(makeSixEntries());
        PredictionResult r = service.predictNextMonthWaste(1L);
        assertTrue(r.isSufficientData());
        assertTrue(r.getPredictedGenerated() >= 0);
        assertNotNull(r.getRiskLevel());
        assertFalse(r.getRecommendations().isEmpty());
    }
}
```

