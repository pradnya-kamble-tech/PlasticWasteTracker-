    class AuditReport {
        -Long id
        -Industry industry
        -User generatedByUser
        -LocalDate periodStart
        -LocalDate periodEnd
        -Double totalGeneratedKg
        -Double totalRecycledKg
        -Double totalEliminatedKg
        -Double reductionRatePercent
        -Double recyclingRatioPercent
        -ReportStatus status
        -LocalDateTime generatedAt
        -String remarks
    }

    class PredictionResult {
        -Long industryId
        -String industryName
        -boolean sufficientData
        -List~WasteDataPoint~ historicalData
        -double predictedGenerated
        -double predictedRecycled
        -double predictedEliminated
        -double predictedRecyclingRate
        -RiskLevel riskLevel
        -String riskReason
        -List~String~ recommendations
        -List~String~ chartLabels
    }

    class WasteDataPoint {
        -int monthIndex
        -String monthLabel
        -double generated
        -double recycled
        -double eliminated
        +getRecyclingRate() double
        +getReductionRate() double
    }

    class PredictionService {
        +predictNextMonthWaste(industryId) PredictionResult
        +getTrendAnalysis(industryId) PredictionResult
        -buildChronologicalDataPoints(id) List
        -linearPredict(x[], y[], xPredict) double
        -computeTrends(result, points) void
        -assessRisk(result) void
        -buildRecommendations(result) List
    }

    class ReportAggregatorService {
        +aggregateReportsForAllIndustries() CompletableFuture
        +buildReport(industry, start, end, user) AuditReport
        +findAllReports() List
        +updateReportStatus(id, status) void
    }

    class AlertServer {
        -ServerSocket serverSocket
        -CopyOnWriteArrayList writers
        +startServer() void
        +broadcastAlert(msg) void
        -handleClient(socket) void
    }

    User "many" --> "many" Role : has
    User "many" --> "1" Industry : belongs to
    Industry "1" --> "many" WasteEntry : has
    Industry "1" --> "many" AuditReport : audited in
    User "1" --> "many" AuditReport : generates
    PredictionResult "1" --> "many" WasteDataPoint : contains
    PredictionService ..> PredictionResult : returns
    PredictionService ..> WasteDataPoint : uses
    ReportAggregatorService ..> AuditReport : creates
```

